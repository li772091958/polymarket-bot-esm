{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "outDir": "dist",
    "rootDir": ".",

    "strict": true,
    "skipLibCheck": true,

    "types": ["node"]
  },
  "ts-node": {
    "esm": true
  },
  "include": ["src/**/*.ts", "web/**/*.ts"]
}
